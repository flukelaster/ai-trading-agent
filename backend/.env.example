# MT5 Bridge (Windows VPS)
MT5_BRIDGE_URL=http://YOUR_VPS_IP:8080
MT5_BRIDGE_API_KEY=your_secret_bridge_key

# Database
DATABASE_URL=postgresql+asyncpg://goldbot:your_password@localhost:5432/goldbot
DATABASE_URL_SYNC=postgresql://goldbot:your_password@localhost:5432/goldbot

# Redis
REDIS_URL=redis://localhost:6379/0

# AI
ANTHROPIC_API_KEY=sk-ant-api03-...
CLAUDE_CODE_OAUTH_TOKEN=

# Bot Config
SYMBOL=GOLD
TIMEFRAME=M15
MAX_RISK_PER_TRADE=0.01
MAX_DAILY_LOSS=0.03
MAX_CONCURRENT_TRADES=3
MAX_LOT=1.0
USE_AI_FILTER=true
AI_CONFIDENCE_THRESHOLD=0.7

# Notifications
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# API
SECRET_KEY=generate_random_32_char_string
CORS_ORIGINS=http://localhost:3000,https://your-vercel-app.vercel.app
